# ============================================================================
# Agentic Document Processor - Environment Variables Example
# Copy this file to .env and fill in your actual API keys and credentials
# ============================================================================

# ============================================================================
# AWS BEDROCK CLAUDE (PRIMARY - Most Reliable, Fast: 3-6s per document)
# ============================================================================
# Using Claude 3 Haiku for best balance of speed, quality, and reliability
# Cost: $0.25/$1.25 per 1M tokens (input/output)
# No rate limits on your AWS account
# Get credentials from: https://aws.amazon.com/bedrock/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=AKIA...your_access_key_here...
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here...
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0


# ============================================================================
# GROQ API (PRIMARY - Fast and Reliable)
# ============================================================================
# Groq offers ultra-fast inference with LPU technology
# Free tier: 30 requests/min, 6000 requests/day
# Get your API key from: https://console.groq.com/keys
# Check current models at: https://console.groq.com/docs/models
GROQ_API_KEY=gsk_your_primary_groq_key_here...
GROQ_API_KEY_B=gsk_your_backup_groq_key_here...
GROQ_API_KEY_C=gsk_your_tertiary_groq_key_here...
GROQ_MODEL=llama-3.1-8b-instant


# ============================================================================
# HuggingFace API (FALLBACK #2 - if Claude and Groq fail)
# ============================================================================
# For gated models like Llama, requires HF account approval
# Get token from: https://huggingface.co/settings/tokens
HF_API_KEY=hf_your_huggingface_token_here...
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct


# ============================================================================
# Local LLM (FALLBACK #3 - Last resort, works offline)
# ============================================================================
# Using Llama 3.1 8B Instruct GGUF (quantized Q4_K_M)
# Model file: models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf (4.7 GB)
# Automatically uses GPU if available (NVIDIA/AMD/Apple Silicon)
LOCAL_MODEL_NAME=local-gguf
LLAMA_MODEL_PATH=./models/Meta-Llama-3.1-8B-Instruct-Q4_K_M.gguf
USE_GPU_INFERENCE=True
LLAMA_N_GPU_LAYERS=35
LLAMA_CONTEXT_LENGTH=512
LLAMA_MAX_TOKENS=64
LLAMA_BATCH_SIZE=256


# ============================================================================
# Ollama Local Server (Optional - Fallback)
# ============================================================================
# Start server with: ollama serve
# Pull model with: ollama pull llama3.1
# Leave as-is if Ollama not running
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1


# ============================================================================
# AWS Infrastructure (SecretsManager, S3, ElastiCache)
# ============================================================================
# Optional: Set if using cloud infrastructure
AWS_S3_BUCKET=agentic-doc-processor
AWS_GROQ_SECRET_NAME=agentic-doc-processor/dev/groq
AWS_LANGSMITH_SECRET_NAME=agentic-doc-processor/dev/langsmith
AWS_REDIS_ENDPOINT=redis://clustercfg.agentic-doc-processor-dev.0javhp.use1.cache.amazonaws.com:6379


# ============================================================================
# LangSmith Observability (Optional - Cloud Tracing)
# ============================================================================
# Enable to trace all LLM calls in LangSmith dashboard
# Get API key from: https://smith.langchain.com/
LANGSMITH_API_KEY=ls_your_langsmith_api_key_here...
LANGSMITH_PROJECT=agentic-doc-processor
LANGSMITH_ENDPOINT=https://api.smith.langchain.com


# ============================================================================
# Flowise Integration (Optional)
# ============================================================================
# For visual workflow builder integration
FLOWISE_API_KEY=your_flowise_api_key_here...
FLOWISE_API_URL=http://localhost:3000


# ============================================================================
# API Configuration
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False


# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO


# ============================================================================
# Tesseract OCR Configuration (Windows)
# ============================================================================
# Linux/macOS: Leave as-is (installed via apt/brew)
# Windows: Update path if Tesseract installed elsewhere
TESSERACT_CMD=C:\\Users\\charanl\\AppData\\Local\\Programs\\Tesseract-OCR\\tesseract.exe


# ============================================================================
# REQUIRED FOR SUBMISSION
# ============================================================================
# Minimum required for project to run:
# - GROQ_API_KEY (primary LLM)
# - AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY (fallback)
# - HF_API_KEY (tertiary fallback)
#
# Optional but recommended:
# - Local GGUF model (already included in repo)
# - Ollama server (for additional offline fallback)
# - LangSmith (for observability/tracing)
